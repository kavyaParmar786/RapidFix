# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_random_secret_here
BETTER_AUTH_URL=http://localhost:3000   # Change to your prod URL on Vercel

# Public URL (same value, needed on client side)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth (console.cloud.google.com) ─────────────────────────────────
# Authorized redirect URI to add: {YOUR_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Firebase (same as before) ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_value
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_value
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_value
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_value
NEXT_PUBLIC_FIREBASE_APP_ID=your_value
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_value
