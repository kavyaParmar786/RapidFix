# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_random_secret_here
BETTER_AUTH_URL=http://localhost:3000   # Change to your prod URL on Vercel

# Public URL (same value, needed on client side)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth (console.cloud.google.com) ─────────────────────────────────
# Authorized redirect URI to add: {YOUR_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Firebase (same as before) ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_value
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_value
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_value
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_value
NEXT_PUBLIC_FIREBASE_APP_ID=your_value
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_value

# ─── Firebase Cloud Messaging (FCM push notifications) ───────────────────────
# Generate VAPID keys: firebase console → project settings → cloud messaging → web push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here

# ─── Cloudinary (image uploads) ──────────────────────────────────────────────
# Free at cloudinary.com — create an unsigned upload preset
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# ─── Razorpay (payments) ─────────────────────────────────────────────────────
# Get from razorpay.com → Settings → API Keys (use TEST keys in dev)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx  # Same as above, exposed to browser

# Webhook secret — Razorpay dashboard → Settings → Webhooks → signing secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Razorpay Payouts / RazorpayX (worker bank transfers) ────────────────────
# Requires a RazorpayX current account — apply at razorpay.com/x
# Your RazorpayX current account number (shown in the RazorpayX dashboard)
RAZORPAY_ACCOUNT_NUMBER=1234567890

# ─── Resend (transactional emails) ───────────────────────────────────────────
# Free at resend.com — 3,000 emails/month on free tier
# Also verify your domain (rapidfix.in) in Resend dashboard for deliverability
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# analytics.google.com → create property → get Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Upstash Redis (optional — for production-grade rate limiting) ────────────
# Free at upstash.com — replace the in-memory rate limiter in middleware.ts
# UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token


# ─── Firebase FCM (push to workers) ──────────────────────────────────────────
# Firebase console → Project settings → Cloud Messaging → Server key (legacy)
FIREBASE_SERVER_KEY=your_fcm_server_key

# ─── Razorpay Subscriptions (Pro worker plan) ─────────────────────────────────
# Create once in Razorpay dashboard → Subscriptions → Plans (₹299/month)
RAZORPAY_SUBSCRIPTION_PLAN_ID=plan_xxxxxxxxxxxxx

# ─── Vercel Cron secret ───────────────────────────────────────────────────────
# Any random string — protects /api/cron/* from unauthorized invocations
CRON_SECRET=any_random_secret_string

# ─── Sentry (error monitoring) ────────────────────────────────────────────────
# Free at sentry.io — install: npm install @sentry/nextjs
# Then: npx @sentry/wizard@latest -i nextjs  (auto-configures everything)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
